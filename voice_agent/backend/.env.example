# Required. Backend exits with a pydantic ValidationError at startup if missing.
GEMINI_API_KEY=

# Gemini model selection.
# Live (native-audio dialog) model for the realtime voice session.
GEMINI_MODEL_ID=gemini-3.1-flash-live-preview
# Text Flash model used for the one-shot post-session summary.
SUMMARIZER_MODEL_ID=gemini-2.5-flash

# Server bind
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765

# Storage
DB_PATH=memory.db
PROMPTS_DIR=prompts

# Logging — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# WebSocket heartbeat. ESP32 Wi-Fi stacks silently drop idle connections;
# pinging well below the typical 60s NAT timeout keeps the socket alive.
WS_PING_INTERVAL_SEC=20

# Session lifecycle (used starting in chunk 2)
SESSION_SILENCE_TIMEOUT_SEC=30
SESSION_MAX_DURATION_SEC=300
